<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========== Sunset Theme ========== -->
    <!-- Background -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF7ED"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFFFF"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#EA580C"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#C2410C"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#FED7AA"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#7C2D12"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9A3412"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FDBA74"/>

    <!-- Borders & Dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#FED7AA"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#FFF7ED"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#BBF7D0"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="#FEF3C7"/>

    <!-- Device Type Colors -->
    <SolidColorBrush x:Key="KeyboardBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="KeyboardLightBrush" Color="#FECACA"/>
    <SolidColorBrush x:Key="MouseBrush" Color="#EA580C"/>
    <SolidColorBrush x:Key="MouseLightBrush" Color="#FED7AA"/>
    <SolidColorBrush x:Key="TouchpadBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="TouchpadLightBrush" Color="#FDE68A"/>
    <SolidColorBrush x:Key="OtherDeviceBrush" Color="#78716C"/>
    <SolidColorBrush x:Key="OtherDeviceLightBrush" Color="#F5F5F4"/>

</ResourceDictionary>