<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme -->
    <Color x:Key="WindowColor">#F8FAFC</Color>
    <Color x:Key="SidebarColor">#FFFFFF</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="PrimaryColor">#3B82F6</Color>
    <Color x:Key="TextPrimaryColor">#1E293B</Color>
    <Color x:Key="TextSecondaryColor">#64748B</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="KeyboardBrush" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="MouseBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="TouchpadBrush" Color="#EC4899"/>
    <SolidColorBrush x:Key="OtherDeviceBrush" Color="#6B7280"/>

</ResourceDictionary>