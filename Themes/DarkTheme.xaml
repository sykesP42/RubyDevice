<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme - High Contrast, Readable -->
    <Color x:Key="WindowColor">#0F172A</Color>
    <Color x:Key="SidebarColor">#1E293B</Color>
    <Color x:Key="CardColor">#1E293B</Color>
    <Color x:Key="PrimaryColor">#60A5FA</Color>
    <Color x:Key="TextPrimaryColor">#F8FAFC</Color>
    <Color x:Key="TextSecondaryColor">#CBD5E1</Color>
    <Color x:Key="BorderColor">#334155</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#334155"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="KeyboardBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="MouseBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="TouchpadBrush" Color="#F472B6"/>
    <SolidColorBrush x:Key="OtherDeviceBrush" Color="#9CA3AF"/>

</ResourceDictionary>