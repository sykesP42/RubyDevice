<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========== Forest Theme ========== -->
    <!-- Background -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F0FDF4"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFFFF"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#15803D"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#BBF7D0"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#14532D"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#166534"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#86EFAC"/>

    <!-- Borders & Dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#BBF7D0"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#F0FDF4"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#BBF7D0"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#CA8A04"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="#FEF9C3"/>

    <!-- Device Type Colors -->
    <SolidColorBrush x:Key="KeyboardBrush" Color="#15803D"/>
    <SolidColorBrush x:Key="KeyboardLightBrush" Color="#BBF7D0"/>
    <SolidColorBrush x:Key="MouseBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="MouseLightBrush" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="TouchpadBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="TouchpadLightBrush" Color="#BBF7D0"/>
    <SolidColorBrush x:Key="OtherDeviceBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="OtherDeviceLightBrush" Color="#F1F5F9"/>

</ResourceDictionary>