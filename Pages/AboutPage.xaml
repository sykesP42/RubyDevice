<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="RubyDevice.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WindowBackgroundBrush}">

    <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600" Spacing="24" HorizontalAlignment="Center">
            <!-- Logo + App Info -->
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <Border Width="80" Height="80" CornerRadius="16" Background="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center">
                    <TextBlock Text="RD" FontSize="28" FontWeight="Bold"
                              Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="RubyDevice" FontSize="26" FontWeight="Bold"
                              HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="VersionText" FontSize="12"
                              HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Description -->
            <TextBlock x:Name="AppDesc" TextWrapping="Wrap" TextAlignment="Center"
                      Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22"/>

            <!-- Features -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="FeaturesTitle" FontSize="16" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <StackPanel x:Name="FeaturesList" Spacing="8"/>
                </StackPanel>
            </Border>

            <!-- Tech Info -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TechInfoTitle" FontSize="16" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="TechFramework"
                                  FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="WinUI 3 / .NET 9"
                                  FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="TechPlatform"
                                  FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Windows 10+ (x64)"
                                  FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="TechSdk"
                                  FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Windows App SDK 1.5"
                                  FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="TechLicense"
                                  FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="MIT License"
                                  FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Links -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="LinksTitle" FontSize="16" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <HyperlinkButton x:Name="GithubLink" NavigateUri="https://github.com/sykesP42/RubyDevice"
                                    Padding="0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE775;" FontSize="14"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="GithubText" FontSize="13"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </HyperlinkButton>
                </StackPanel>
            </Border>

            <!-- Copyright -->
            <TextBlock x:Name="CopyrightText" FontSize="11"
                      Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</Page>
