<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="RubyDevice.Pages.TimerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RubyDevice.ViewModels"
    Background="{StaticResource WindowBackgroundBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel Spacing="20">
            <!-- Timer Control -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="24"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Controls -->
                    <StackPanel Grid.Column="0" Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="TimerTitle" FontSize="20" FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="TimerDesc" FontSize="13" TextWrapping="Wrap"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Timer state indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border x:Name="StateIndicator" Width="8" Height="8" CornerRadius="4"
                                   Background="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TimerState" FontSize="13"
                                      Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <NumberBox Grid.Column="0" x:Name="TimeoutBox" Value="30"
                                          Minimum="1" Maximum="480" SpinButtonPlacementMode="Inline"
                                          ValueChanged="TimeoutBox_ValueChanged"/>

                                <Button Grid.Column="1" x:Name="BtnStart" Click="BtnStart_Click"
                                       Padding="16,10" MinWidth="80">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" FontSize="14"/>
                                        <TextBlock x:Name="TextStart"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="2" x:Name="BtnStop" Click="BtnStop_Click"
                                       Padding="16,10" MinWidth="80" IsEnabled="False"
                                       Background="#FEE2E2" Foreground="#DC2626">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                                        <TextBlock x:Name="TextStop"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Quick Presets -->
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="PresetsTitle" FontSize="12"
                                          Foreground="{StaticResource TextTertiaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="5 min" Padding="12,6" CornerRadius="6"
                                           Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                           BorderThickness="1" Foreground="{StaticResource TextSecondaryBrush}"
                                           Click="Preset_Click" Tag="5"/>
                                    <Button Content="15 min" Padding="12,6" CornerRadius="6"
                                           Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                           BorderThickness="1" Foreground="{StaticResource TextSecondaryBrush}"
                                           Click="Preset_Click" Tag="15"/>
                                    <Button Content="30 min" Padding="12,6" CornerRadius="6"
                                           Background="{StaticResource PrimaryBrush}" Foreground="White"
                                           Click="Preset_Click" Tag="30"/>
                                    <Button Content="1 hr" Padding="12,6" CornerRadius="6"
                                           Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                           BorderThickness="1" Foreground="{StaticResource TextSecondaryBrush}"
                                           Click="Preset_Click" Tag="60"/>
                                    <Button Content="2 hr" Padding="12,6" CornerRadius="6"
                                           Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                                           BorderThickness="1" Foreground="{StaticResource TextSecondaryBrush}"
                                           Click="Preset_Click" Tag="120"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right: Timer Display -->
                    <Border Grid.Column="1" Width="120" Height="120" CornerRadius="16"
                           Background="{StaticResource PrimaryBrush}">
                        <StackPanel VerticalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xE916;" FontSize="32" Foreground="White"
                                     HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TimerDisplay" Text="30:00" FontSize="28"
                                      FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TimerUnitText" Text="minutes" FontSize="11"
                                      Foreground="White" Opacity="0.8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Disabled Devices to Restore -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="DisabledTitle" FontSize="18" FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Border Grid.Column="1" x:Name="DisabledCountBadge" Background="{StaticResource DividerBrush}"
                                       CornerRadius="8" Padding="6,2" MinWidth="20">
                                    <TextBlock x:Name="DisabledCount" FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="DisabledDesc" FontSize="12"
                                      Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="BtnRestoreAll" Click="BtnRestoreAll_Click"
                               Padding="12,6" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock x:Name="TextRestoreAll"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView x:Name="DisabledList" SelectionMode="None" MaxHeight="240">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DeviceViewModel">
                                <Grid Padding="8,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6"
                                           Background="{StaticResource CardBackgroundBrush}">
                                        <TextBlock Text="{x:Bind IconGlyph}" FontFamily="Segoe MDL2 Assets"
                                                  FontSize="12" HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontSize="13" FontWeight="Medium"
                                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind TypeName}" FontSize="11"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{x:Bind StatusText}" FontSize="12"
                                              Foreground="{StaticResource DangerBrush}"
                                              VerticalAlignment="Center"/>

                                    <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                 OnContent="" OffContent=""
                                                 Toggled="ToggleSwitch_Toggled"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
