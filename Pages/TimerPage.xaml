<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="RubyDevice.Pages.TimerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WindowBackgroundBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel Spacing="20">
            <!-- Auto Restore Timer -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="16">
                        <TextBlock x:Name="TimerTitle" FontSize="18" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TimerDesc" TextWrapping="Wrap"
                                  Foreground="{StaticResource TextSecondaryBrush}"/>

                        <StackPanel Spacing="12">
                            <ToggleSwitch x:Name="EnableTimerToggle"/>
                            <NumberBox x:Name="TimeoutBox" Value="30" Minimum="1" Maximum="480"
                                      SpinButtonPlacementMode="Inline"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Width="80" Height="80" CornerRadius="12"
                           Background="{StaticResource PrimaryBrush}">
                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE916;" FontSize="24" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TimerDisplay" Text="30:00" FontSize="16" FontWeight="Bold"
                                      Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Quick Presets -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="PresetsTitle" FontSize="18" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="5 min" Padding="14,10" CornerRadius="6"
                               Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Click="Preset_Click" Tag="5"/>
                        <Button Content="15 min" Padding="14,10" CornerRadius="6"
                               Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Click="Preset_Click" Tag="15"/>
                        <Button Content="30 min" Padding="14,10" CornerRadius="6"
                               Background="{StaticResource PrimaryBrush}" Foreground="White"
                               Click="Preset_Click" Tag="30"/>
                        <Button Content="1 hr" Padding="14,10" CornerRadius="6"
                               Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Click="Preset_Click" Tag="60"/>
                        <Button Content="2 hr" Padding="14,10" CornerRadius="6"
                               Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Click="Preset_Click" Tag="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Disabled Devices -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="DisabledTitle" FontSize="18" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="DisabledDesc" Foreground="{StaticResource TextSecondaryBrush}"/>

                    <ListView x:Name="DisabledList" Margin="0,8,0,0" MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="4" Margin="0,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                              Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding TypeName}" FontSize="12"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>