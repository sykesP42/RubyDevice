<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="RubyDevice.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WindowBackgroundBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel Spacing="20">
            <!-- Appearance Section -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextAppearanceTitle" FontSize="18" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TextAppearanceDesc" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <!-- Language -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="TextLanguageLabel" FontSize="14"
                                  Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <RadioButtons Grid.Column="1" x:Name="LanguageRadio"
                                     SelectionChanged="LanguageRadio_SelectionChanged">
                            <RadioButton Content="English" Tag="English"/>
                            <RadioButton Content="中文" Tag="Chinese"/>
                        </RadioButtons>
                    </Grid>

                    <!-- Theme -->
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="TextThemeLabel" FontSize="14"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <GridView x:Name="ThemeGrid" SelectionMode="Single"
                                 SelectionChanged="ThemeGrid_SelectionChanged">
                            <GridViewItem Tag="Light" Margin="0,0,12,0"
                                     ToolTipService.ToolTip="Light">
                                <StackPanel Spacing="8" Width="72">
                                    <Border Width="48" Height="48" CornerRadius="8"
                                           Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="2"/>
                                    <TextBlock x:Name="TextThemeLight" HorizontalAlignment="Center" FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </GridViewItem>
                            <GridViewItem Tag="Dark" Margin="0,0,12,0"
                                     ToolTipService.ToolTip="Dark">
                                <StackPanel Spacing="8" Width="72">
                                    <Border Width="48" Height="48" CornerRadius="8" Background="#0F172A"/>
                                    <TextBlock x:Name="TextThemeDark" HorizontalAlignment="Center" FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </GridViewItem>
                            <GridViewItem Tag="Ocean" Margin="0,0,12,0"
                                     ToolTipService.ToolTip="Ocean">
                                <StackPanel Spacing="8" Width="72">
                                    <Border Width="48" Height="48" CornerRadius="8" Background="#0891B2"/>
                                    <TextBlock x:Name="TextThemeOcean" HorizontalAlignment="Center" FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </GridViewItem>
                            <GridViewItem Tag="Forest" Margin="0,0,12,0"
                                     ToolTipService.ToolTip="Forest">
                                <StackPanel Spacing="8" Width="72">
                                    <Border Width="48" Height="48" CornerRadius="8" Background="#16A34A"/>
                                    <TextBlock x:Name="TextThemeForest" HorizontalAlignment="Center" FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </GridViewItem>
                            <GridViewItem Tag="Sunset" Margin="0,0,12,0"
                                     ToolTipService.ToolTip="Sunset">
                                <StackPanel Spacing="8" Width="72">
                                    <Border Width="48" Height="48" CornerRadius="8" Background="#EA580C"/>
                                    <TextBlock x:Name="TextThemeSunset" HorizontalAlignment="Center" FontSize="11"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </GridViewItem>
                        </GridView>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Behavior Section -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextBehaviorTitle" FontSize="18" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TextBehaviorDesc" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="TextAutoStart" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="AutoStartToggle"
                                     Toggled="AutoStart_Toggled"/>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="TextAutoRefresh" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="AutoRefreshToggle"
                                     Toggled="AutoRefresh_Toggled"/>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="TextShowNotifications" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="NotificationsToggle"
                                     Toggled="Notifications_Toggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- System Tray Section -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextTrayTitle" FontSize="18" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TextTrayDesc" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="TextMinimizeToTray" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="MinimizeToTrayToggle"
                                     Toggled="MinimizeToTray_Toggled"/>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="TextShowDeviceCount" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="ShowDeviceCountToggle"
                                     Toggled="ShowDeviceCount_Toggled"/>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="TextCloseToTray" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="CloseToTrayToggle"
                                     Toggled="CloseToTray_Toggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Data Management Section -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextDataTitle" FontSize="18" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TextDataDesc" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <Button x:Name="BtnClearData" Click="BtnClearData_Click"
                            Background="#FEE2E2" Foreground="#DC2626"
                            HorizontalAlignment="Left" Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                            <TextBlock x:Name="TextClearData"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- About Section -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="20"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextAboutTitle" FontSize="18" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TextAboutDesc" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                               Background="{StaticResource PrimaryBrush}">
                            <TextBlock Text="RD" FontSize="18" FontWeight="Bold"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Foreground="White"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="RubyDevice" FontSize="16" FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="TextVersion" FontSize="12"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TextAboutDescText" FontSize="12"
                                      Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
