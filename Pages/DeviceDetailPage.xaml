<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="RubyDevice.Pages.DeviceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RubyDevice.ViewModels"
    Background="{StaticResource WindowBackgroundBrush}">

    <ScrollViewer Padding="24,20">
        <StackPanel Spacing="16" MaxWidth="800">
            <!-- Back Button -->
            <Button Click="Back_Click" HorizontalAlignment="Left" Padding="12,6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="12"/>
                    <TextBlock x:Name="TextBack"/>
                </StackPanel>
            </Button>

            <!-- Header -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="12"
                       Background="{StaticResource PrimaryLightBrush}">
                    <TextBlock x:Name="DeviceIcon" FontFamily="Segoe MDL2 Assets" FontSize="24"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Foreground="{StaticResource PrimaryBrush}"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="DeviceNameText" FontSize="20" FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="DeviceTypeText" FontSize="13"
                              Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border CornerRadius="6" Padding="8,4" Background="{StaticResource PrimaryLightBrush}">
                        <TextBlock x:Name="DeviceStatus" FontWeight="Medium"
                                  Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <ToggleSwitch x:Name="DeviceToggle" OnContent="" OffContent=""
                                 Toggled="DeviceToggle_Toggled"/>
                </StackPanel>
            </Grid>

            <!-- Device Info Card -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TextDeviceInfo" FontSize="14" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <Grid ColumnSpacing="24" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="TextManufacturer" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="InfoManufacturer" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="TextVid" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="InfoVid" FontSize="13" FontFamily="Consolas"
                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="TextPid" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="InfoPid" FontSize="13" FontFamily="Consolas"
                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock x:Name="TextConnection" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="InfoConnection" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="TextDeviceId" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="InfoDeviceId" FontSize="11" FontFamily="Consolas"
                                  Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Usage Statistics Card -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TextUsageStats" FontSize="14" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <!-- Today's Stats -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource DividerBrush}" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="TextActiveTime" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="ValueActiveTime" FontSize="18" FontWeight="Bold"
                                          Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource DividerBrush}" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="TextEnabledTime" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="ValueEnabledTime" FontSize="18" FontWeight="Bold"
                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Tracking Toggle -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="TextTracking" VerticalAlignment="Center"
                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ToggleSwitch x:Name="TrackingToggle" OnContent="" OffContent=""
                                      Toggled="TrackingToggle_Toggled"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Usage History Chart -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock x:Name="TextHistory" FontSize="14" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <RadioButton x:Name="Range7Days" GroupName="HistoryRange" Tag="7"
                                        Click="Range_Click" IsChecked="True" Padding="8,4"/>
                            <RadioButton x:Name="Range30Days" GroupName="HistoryRange" Tag="30"
                                        Click="Range_Click" Padding="8,4"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chart Legend -->
                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="12" Height="12" CornerRadius="2" Background="#3B82F6"/>
                            <TextBlock x:Name="LegendActive" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="12" Height="12" CornerRadius="2" Background="#10B981"/>
                            <TextBlock x:Name="LegendEnabled" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Chart Area with Y-Axis -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Y-Axis Labels -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Height="120">
                            <TextBlock x:Name="YAxisMax" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                      HorizontalAlignment="Right" VerticalAlignment="Top"/>
                            <TextBlock x:Name="YAxisMid" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock x:Name="YAxisMin" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                      Text="0" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </StackPanel>

                        <!-- Chart Canvas -->
                        <Border Grid.Column="1" Background="{StaticResource DividerBrush}" CornerRadius="6" Padding="4">
                            <Canvas x:Name="ChartCanvas" Height="120" HorizontalAlignment="Stretch"/>
                        </Border>
                    </Grid>

                    <!-- X-Axis Labels -->
                    <StackPanel x:Name="XAxisLabels" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="0"
                               Margin="40,4,4,0"/>
                </StackPanel>
            </Border>

            <!-- Notes Card -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TextNotes" FontSize="14" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBox x:Name="NoteBox" PlaceholderText="..."
                            AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                            LostFocus="NoteBox_LostFocus"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>