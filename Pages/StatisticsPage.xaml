<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="RubyDevice.Pages.StatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RubyDevice.ViewModels"
    Background="{StaticResource WindowBackgroundBrush}">

    <ScrollViewer Padding="24,16">
        <StackPanel Spacing="16">
            <!-- Stats Cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="12"
                       BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextTotal" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CountTotal" Text="0" FontSize="24" FontWeight="Bold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="12"
                       BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextActive" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CountActive" Text="0" FontSize="24" FontWeight="Bold"
                                  Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="12"
                       BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextDisabled" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CountDisabled" Text="0" FontSize="24" FontWeight="Bold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="12"
                       BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="TextExternal" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CountExternal" Text="0" FontSize="24" FontWeight="Bold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Device Distribution -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="16"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TextDistribution" FontSize="14" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <StackPanel Spacing="8">
                        <!-- Keyboards -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="TextKeyboard" FontSize="12"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Grid.Column="1" Height="20" CornerRadius="4" Background="{StaticResource DividerBrush}">
                                <Border x:Name="BarKeyboard" Height="20" CornerRadius="4"
                                       Background="{StaticResource PrimaryBrush}" HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Grid.Column="2" x:Name="CountKeyboard" FontSize="12" Margin="4,0,0,0"
                                      Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Mice -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="TextMouse" FontSize="12"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Grid.Column="1" Height="20" CornerRadius="4" Background="{StaticResource DividerBrush}">
                                <Border x:Name="BarMouse" Height="20" CornerRadius="4"
                                       Background="#10B981" HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Grid.Column="2" x:Name="CountMouse" FontSize="12" Margin="4,0,0,0"
                                      Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Touchpads -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="TextTouchpad" FontSize="12"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Grid.Column="1" Height="20" CornerRadius="4" Background="{StaticResource DividerBrush}">
                                <Border x:Name="BarTouchpad" Height="20" CornerRadius="4"
                                       Background="#F59E0B" HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Grid.Column="2" x:Name="CountTouchpad" FontSize="12" Margin="4,0,0,0"
                                      Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Today's Usage -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="16"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock x:Name="TextTodayUsage" FontSize="14" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button HorizontalAlignment="Right" Click="BtnRefresh_Click" Padding="8,4">
                            <TextBlock x:Name="TextRefresh"/>
                        </Button>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource DividerBrush}" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="TextActiveTime" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="ValueActiveTime" FontSize="20" FontWeight="Bold"
                                          Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource DividerBrush}" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="TextEnabledTime" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="ValueEnabledTime" FontSize="20" FontWeight="Bold"
                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Tracked devices count -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="TextTrackedCount" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="CountTracked" FontSize="12" FontWeight="Bold"
                                  Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Device List -->
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="16"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="TextDeviceList" FontSize="14" FontWeight="SemiBold"
                              Foreground="{StaticResource TextPrimaryBrush}"/>

                    <ListView x:Name="UsageList" SelectionMode="None" MaxHeight="250">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DeviceViewModel">
                                <Grid Padding="8,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontSize="13" FontWeight="Medium"
                                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind TypeName}" FontSize="11"
                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{x:Bind StatusText}" FontSize="12"
                                              VerticalAlignment="Center"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <TextBlock Grid.Column="2" Text="{x:Bind UsageTimeText}" FontSize="12"
                                              VerticalAlignment="Center"
                                              Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>