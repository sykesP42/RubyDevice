<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="RubyDevice.Pages.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RubyDevice.ViewModels"
    Background="{StaticResource WindowBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter -->
        <Border Grid.Row="0" Padding="20,12" Background="{StaticResource HeaderBackgroundBrush}"
               BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <RadioButton x:Name="FilterAll" Content="All" GroupName="Filter" IsChecked="True"
                                Click="Filter_Click" Tag="All" Padding="12,6" CornerRadius="6"/>
                    <RadioButton x:Name="FilterKeyboard" GroupName="Filter" Click="Filter_Click" Tag="Keyboard" Padding="12,6" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE765;" FontSize="12"/>
                            <TextBlock x:Name="TextKeyboard"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="FilterMouse" GroupName="Filter" Click="Filter_Click" Tag="Mouse" Padding="12,6" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE962;" FontSize="12"/>
                            <TextBlock x:Name="TextMouse"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="FilterTouchpad" GroupName="Filter" Click="Filter_Click" Tag="Touchpad" Padding="12,6" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEFA5;" FontSize="12"/>
                            <TextBlock x:Name="TextTouchpad"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <Button Grid.Column="2" x:Name="BtnRefresh" Click="BtnRefresh_Click"
                       Background="{StaticResource PrimaryBrush}" Foreground="White"
                       CornerRadius="6" Padding="12,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                        <TextBlock x:Name="TextRefresh" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Devices -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20,0,20,16">
                <ItemsControl ItemsSource="{x:Bind ViewModel.DeviceGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DeviceGroupViewModel">
                            <StackPanel Spacing="12" Margin="0,0,0,20">
                                <!-- Group Header -->
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="32" Height="32" CornerRadius="6" Background="{StaticResource PrimaryLightBrush}">
                                        <TextBlock Text="{x:Bind IconGlyph}" FontFamily="Segoe MDL2 Assets"
                                                  FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Name}" FontSize="16" FontWeight="SemiBold"
                                              VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Border Background="{StaticResource DividerBrush}" CornerRadius="8" Padding="6,2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Devices.Count}" FontSize="11"
                                                  Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <!-- Devices -->
                                <ItemsControl ItemsSource="{x:Bind Devices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DeviceViewModel">
                                            <Border Background="{StaticResource CardBackgroundBrush}"
                                                   CornerRadius="8" Padding="16" Margin="0,0,0,8"
                                                   BorderBrush="{x:Bind ActiveBrush}" BorderThickness="3"
                                                   PointerPressed="Device_Click" Tag="{x:Bind}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon with activity glow -->
                                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                           Background="{StaticResource PrimaryLightBrush}" Margin="0,0,14,0">
                                                        <Grid>
                                                            <TextBlock Text="{x:Bind IconGlyph}" FontFamily="Segoe MDL2 Assets"
                                                                      FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                      Foreground="{StaticResource PrimaryBrush}"/>
                                                            <!-- Activity dot overlay -->
                                                            <Border Width="12" Height="12" CornerRadius="6"
                                                                   Background="{x:Bind ActiveBrush}"
                                                                   HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                   Margin="0,-4,-4,0"/>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Info -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock Text="{x:Bind Name}" FontWeight="Medium" FontSize="13"
                                                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <Border Background="{StaticResource DividerBrush}" CornerRadius="3" Padding="5,1">
                                                                <TextBlock Text="{x:Bind TypeName}" FontSize="10"
                                                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </Border>
                                                            <Border Background="{StaticResource DividerBrush}" CornerRadius="3" Padding="5,1">
                                                                <TextBlock Text="{x:Bind LocationText}" FontSize="10"
                                                                          Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Status -->
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="10,4"
                                                           VerticalAlignment="Center" Margin="0,0,14,0"
                                                           Background="{x:Bind StatusColorBrush}">
                                                        <TextBlock Text="{x:Bind StatusText}" FontSize="11"
                                                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    </Border>

                                                    <!-- Toggle -->
                                                    <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                OnContent="" OffContent="" Width="44"
                                                                Toggled="ToggleSwitch_Toggled" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>