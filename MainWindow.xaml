<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="RubyDevice.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}"
              BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="138"/>
            </Grid.ColumnDefinitions>

            <!-- App Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0">
                <TextBlock Text="&#xE96E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                          VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="RubyDevice" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0"
                          VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>

            <!-- Window Buttons - using simple Button with transparent background -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                       Spacing="0">
                <Button x:Name="BtnMinimize" Width="46" Height="32"
                       Background="Transparent" BorderThickness="0" Padding="0"
                       Click="BtnMinimize_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1A000000"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#33000000"/>
                    </Button.Resources>
                    <FontIcon Glyph="&#xE921;" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
                <Button x:Name="BtnMaximize" Width="46" Height="32"
                       Background="Transparent" BorderThickness="0" Padding="0"
                       Click="BtnMaximize_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1A000000"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#33000000"/>
                    </Button.Resources>
                    <FontIcon Glyph="&#xE922;" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
                <Button x:Name="BtnClose" Width="46" Height="32"
                       Background="Transparent" BorderThickness="0" Padding="0"
                       Click="BtnClose_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C42B1C"/>
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#A02619"/>
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                    </Button.Resources>
                    <FontIcon Glyph="&#xE8BB;" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}"
                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Navigation -->
                <ListView Grid.Row="0" x:Name="NavList" SelectionMode="Single"
                         SelectionChanged="NavList_SelectionChanged" Background="Transparent"
                         Padding="8" Margin="0">
                    <ListViewItem x:Name="NavItemDevices" Tag="Devices" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon x:Name="IconDevices" Glyph="&#xE765;" FontSize="16"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TextDevices" VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavItemUsageRecord" Tag="UsageRecord" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon x:Name="IconUsageRecord" Glyph="&#xE9D9;" FontSize="16"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TextUsageRecord" VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavItemStatistics" Tag="Statistics" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon x:Name="IconStatistics" Glyph="&#xE9D9;" FontSize="16"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TextStatistics" VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavItemTimer" Tag="Timer" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon x:Name="IconTimer" Glyph="&#xE916;" FontSize="16"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TextTimer" VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavItemSettings" Tag="Settings" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon x:Name="IconSettings" Glyph="&#xE713;" FontSize="16"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TextSettings" VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavItemAbout" Tag="About" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon x:Name="IconAbout" Glyph="&#xE946;" FontSize="16"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="TextAbout" VerticalAlignment="Center"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </ListViewItem>
                </ListView>

                <!-- Footer -->
                <Border Grid.Row="1" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <TextBlock Text="v1.0.0" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                </Border>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Column="1" Background="{StaticResource WindowBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="20,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="HeaderTitle" FontSize="20" FontWeight="Bold"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="HeaderSubtitle" FontSize="12" Margin="0,2,0,0"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Frame -->
                <Frame x:Name="ContentFrame" Grid.Row="1"/>
            </Grid>
        </Grid>
    </Grid>
</Window>