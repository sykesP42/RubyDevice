<?xml version="1.0" encoding="utf-8"?>
<ContentDialog x:Class="RubyDevice.Controls.AutoRestoreDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="{x:Bind KeepDisabledText}"
    CloseButtonText="{x:Bind RestoreText}"
    DefaultButton="Primary"
    RequestedTheme="Dark">

    <StackPanel Spacing="16" Padding="8" MaxWidth="360">
        <!-- Status Header -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <Border Background="#FFE53E3E" CornerRadius="20" Padding="8">
                <FontIcon Glyph="&#xE73E;" FontSize="18" Foreground="White"/>
            </Border>
            <TextBlock Text="{x:Bind DialogTitle}" FontSize="18" FontWeight="Bold"
                      Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Device Info -->
        <TextBlock Text="{x:Bind DeviceName}" TextWrapping="Wrap" FontSize="14"
                  Foreground="#CCFFFFFF"/>

        <!-- Countdown Section -->
        <Border Background="#3F000000" CornerRadius="8" Padding="12">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind CountdownLabel}" FontSize="11"
                          Foreground="#FF10B981" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CountdownText" FontSize="32" FontWeight="Bold"
                          Foreground="#FF10B981" HorizontalAlignment="Center"/>
                <ProgressRing IsActive="True" Width="16" Height="16" Foreground="#FF10B981"
                             HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Hint -->
        <TextBlock Text="{x:Bind HintText}" TextWrapping="Wrap" FontSize="11"
                  Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
    </StackPanel>
</ContentDialog>