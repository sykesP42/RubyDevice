<?xml version="1.0" encoding="utf-8"?>
<ContentDialog x:Class="RubyDevice.Controls.EnableConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="{x:Bind ConfirmText}"
    CloseButtonText="{x:Bind CancelText}"
    DefaultButton="Primary">

    <StackPanel Spacing="16" Padding="8">
        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <Border Background="#FF10B981" CornerRadius="20" Padding="8">
                <FontIcon Glyph="&#xEC92;" FontSize="20" Foreground="White"/>
            </Border>
            <TextBlock Text="{x:Bind DialogTitle}" FontSize="20" FontWeight="Bold"
                      Foreground="#FF10B981" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Message -->
        <TextBlock Text="{x:Bind Message}" TextWrapping="Wrap" FontSize="14"
                  Foreground="{StaticResource TextPrimaryBrush}"/>
    </StackPanel>
</ContentDialog>